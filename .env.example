# A wallet monitorada NÃO fica aqui — você a define no próprio dashboard
# (ela é salva localmente no banco em data/, que não vai para o git).

# Fuso para fechamento do "dia" (meia-noite a meia-noite). Não mexer salvo necessidade.
TIMEZONE=America/Sao_Paulo

# Porta do backend
PORT=4000

# Intervalo do ciclo incremental (ms)
POLL_INTERVAL_MS=60000

# APIs (defaults já corretos)
KERYX_API=https://keryx-labs.com/api/v1
NONKYC_URL=https://nonkyc.io/api/v2/market/getbysymbol/KRX_USDT
